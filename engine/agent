#!/bin/bash
# adapter: Makefile <-> pi harness. Roles: plan | build <id> | review
# Prompts live in prompts/*.md as ${VAR} templates (python string.Template).
# Swap point: replace PI array for claude -p / other harness.
set -euo pipefail
DIR=$(cd "$(dirname "$0")" && pwd)
PI=(pi -p --no-session --no-context-files --no-skills --no-prompt-templates --no-extensions)
B=${B:-build} SRC=${SRC:-src}

render() {  # render <prompt.md> — substitutes ${VARS} from environment
  python3 -c 'import sys,os
from string import Template
print(Template(open(sys.argv[1]).read()).safe_substitute(os.environ))' "$DIR/prompts/$1"
}

role=$1; shift
case $role in
  plan)
    GOAL_TEXT=$(cat "$1") "${PI[@]}" --no-tools "$(render plan.md)" | sed '/^```/d'
    ;;
  build)
    id=$1
    ID=$id \
    DESC=$(jq -r --arg id "$id" '.components[] | select(.id==$id) | .desc' "$B/plan.json") \
    GOAL_TEXT=$(cat "${GOAL:-goal.md}") \
    SIBLINGS=$(ls "$SRC" 2>/dev/null | tr '\n' ' ' || echo none) \
    SRC=$SRC \
    "${PI[@]}" "$(render build.md)"
    ;;
  review)
    GOAL_FILE=${GOAL:-goal.md} SRC=$SRC "${PI[@]}" "$(render review.md)"
    ;;
  *) echo "unknown role: $role" >&2; exit 1 ;;
esac
